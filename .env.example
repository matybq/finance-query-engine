# Copy this file to .env and fill in the required API keys.
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_PROVIDER=openrouter
# Use openai/gpt-4o-mini via OpenRouter, or gpt-4o-mini when LLM_PROVIDER=openai.
# LLM_MODEL=openai/gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed
# CHROMA_PERSIST_DIR=data/processed/chroma

# Optional LangSmith tracing (see README > Observability).
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=finance-query-engine-dev
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_WORKSPACE_ID=
# LANGCHAIN_CALLBACKS_BACKGROUND=false
